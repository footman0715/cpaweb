---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { featuredNews, site } from '../../data/site';
---

<BaseLayout
  title={`稅務新聞 — 台中會計師的稅務解讀 | ${site.name}`}
  description="奇承聯合會計師事務所每月整理最新稅務法規、財政部公告與實務解讀,協助中小企業掌握稅務脈動。"
  breadcrumb={[
    { name: '首頁', url: site.url },
    { name: '稅務新聞', url: `${site.url}/tax-news/` },
  ]}
>
  <section class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
    <nav class="text-xs text-[color:var(--color-text-muted)] mb-8">
      <a href="/" class="hover:text-[color:var(--color-ink)]">首頁</a> /
      <span class="text-[color:var(--color-ink)]">稅務新聞</span>
    </nav>

    <p class="eyebrow mb-4">INSIGHTS</p>
    <h1 class="text-5xl md:text-7xl font-black text-[color:var(--color-ink)] tracking-tight">
      稅務新聞
    </h1>
    <p class="mt-6 text-lg text-[color:var(--color-text-muted)] max-w-[720px] leading-relaxed">
      每月整理與中小企業切身相關的稅務法規、財政部公告與實務解讀。
    </p>

    <ul class="mt-16 border-t border-[color:var(--color-hairline)]">
      {featuredNews.map((a) => (
        <li class="border-b border-[color:var(--color-hairline)]">
          <a href={`/tax-news/${a.slug}/`} class="group grid grid-cols-[140px_1fr_40px] gap-6 py-8 items-start">
            <div class="flex flex-col gap-2">
              <time class="font-tabular text-sm text-[color:var(--color-ink)]">{a.date}</time>
              <span class="text-[11px] uppercase tracking-[0.18em] text-[color:var(--color-gold)] font-semibold">
                {a.category}
              </span>
            </div>
            <div>
              <h2 class="text-xl md:text-2xl font-bold text-[color:var(--color-ink)] tracking-tight leading-snug">
                {a.title}
              </h2>
              <p class="mt-3 text-sm text-[color:var(--color-text-muted)] leading-relaxed">
                {a.excerpt}
              </p>
            </div>
            <span class="text-xl text-[color:var(--color-ink)] group-hover:translate-x-1 transition-transform" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
