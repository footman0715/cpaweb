---
import { site, nav } from '../data/site';
---

<header class="sticky top-0 z-50 bg-[color:var(--color-canvas)]/85 backdrop-blur-md border-b border-[color:var(--color-hairline)]/60">
  <div class="max-w-[1400px] mx-auto flex items-center justify-between px-6 lg:px-10 h-20">
    <a href="/" class="flex flex-col leading-tight">
      <span class="text-[17px] lg:text-lg font-black tracking-tight text-[color:var(--color-ink)]">
        {site.name}
      </span>
      <span class="text-[10px] uppercase tracking-[0.25em] text-[color:var(--color-text-muted)] mt-0.5">
        {site.brand}
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-10 text-[15px] font-medium text-[color:var(--color-ink)]">
      {nav.map((item) => (
        <a
          href={item.href}
          class="relative hover:text-[color:var(--color-ink-deep)] transition-colors after:content-[''] after:absolute after:left-0 after:-bottom-1 after:h-px after:w-0 after:bg-[color:var(--color-gold)] hover:after:w-full after:transition-all after:duration-300"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-5">
      <a href="/login/" class="hidden md:inline text-sm text-[color:var(--color-ink)] hover:text-[color:var(--color-ink-deep)]">
        會員登入
      </a>
      <a
        href="/contact/"
        class="bg-[color:var(--color-signal)] text-[color:var(--color-ink-deep)] text-sm font-bold px-5 py-2.5 rounded-[6px] hover:opacity-90 transition-opacity"
      >
        免費諮詢
      </a>
    </div>
  </div>
</header>
