---
import { site } from '../../data/site';

const mapQuery = encodeURIComponent(site.address);
---

<section class="bg-[color:var(--color-ink)] text-[color:var(--color-canvas)]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <div>
        <p class="eyebrow mb-4" style="color: var(--color-gold-soft)">CONTACT</p>
        <h2 class="text-4xl md:text-5xl font-black tracking-tight">
          與我們談談<br />您的需求
        </h2>
        <p class="mt-6 text-lg opacity-80 leading-relaxed max-w-[440px]">
          免費初談,依您的事業階段提供最適合的服務建議。
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-6">
          <a
            href="/contact/"
            class="inline-flex items-center gap-2 bg-[color:var(--color-signal)] text-[color:var(--color-ink-deep)] font-bold px-7 py-3.5 rounded-[6px] hover:opacity-90 transition-opacity"
          >
            預約免費諮詢 <span aria-hidden="true">→</span>
          </a>
          <a
            href={`tel:${site.telE164}`}
            class="text-sm opacity-80 hover:opacity-100 border-b border-transparent hover:border-[color:var(--color-gold-soft)] pb-0.5"
          >
            或直撥 {site.tel}
          </a>
        </div>

        <dl class="mt-14 grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] opacity-60 mb-2">地址</dt>
            <dd>{site.address}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] opacity-60 mb-2">營業時間</dt>
            <dd>{site.hours}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] opacity-60 mb-2">電話</dt>
            <dd class="font-tabular">{site.tel}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.2em] opacity-60 mb-2">Email</dt>
            <dd><a href={`mailto:${site.email}`} class="hover:opacity-80">{site.email}</a></dd>
          </div>
        </dl>
      </div>

      <div class="relative h-[400px] lg:h-[500px] rounded-[4px] overflow-hidden border border-[color:var(--color-gold)]/20">
        <iframe
          src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
          width="100%"
          height="100%"
          style="border:0; filter: grayscale(0.3) contrast(0.95);"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="奇承聯合會計師事務所地圖"
        ></iframe>
      </div>
    </div>
  </div>
</section>
