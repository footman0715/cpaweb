---
import { whyUs } from '../../data/site';
---

<section class="bg-[color:var(--color-canvas)] py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <p class="eyebrow mb-4">WHY CICPAFIRM</p>
    <h2 class="text-4xl md:text-5xl font-black text-[color:var(--color-ink)] tracking-tight">
      為什麼選擇奇承
    </h2>
    <p class="mt-4 text-base text-[color:var(--color-text-muted)]">
      四個我們持續被客戶選擇的理由。
    </p>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-0">
      {whyUs.map((item, i) => (
        <div class:list={[
          'px-0 lg:px-8',
          i > 0 && 'lg:border-l lg:border-[color:var(--color-gold)]/30',
        ]}>
          <span class="font-tabular text-5xl font-light text-[color:var(--color-gold)]">
            {item.num}
          </span>
          <h3 class="mt-6 text-xl font-bold text-[color:var(--color-ink)] tracking-tight">
            {item.title}
          </h3>
          <p class="mt-3 text-[15px] leading-[1.8] text-[color:var(--color-text-muted)]">
            {item.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
